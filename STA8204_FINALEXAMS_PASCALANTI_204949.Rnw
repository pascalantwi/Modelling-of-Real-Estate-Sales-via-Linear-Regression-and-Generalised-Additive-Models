library(reshape2)
# Define the selected variables
selected_vars <- c("X1","X2","X3","X4","X6","X11")

# Subset the sales_data dataframe to include only the selected variables
df_selected <- data[, selected_vars]

names(df_selected)[names(df_selected) == "X1"] <- "Salesprice"
names(df_selected)[names(df_selected) == "X2"] <- "Finishedsquareft"
names(df_selected)[names(df_selected) == "X3"] <- "Numberofbedrooms"
names(df_selected)[names(df_selected) == "X4"] <- "Numberofbathrooms"
names(df_selected)[names(df_selected) == "X6"] <- "Garagesize"
names(df_selected)[names(df_selected) == "X11"] <- "Lotsize"
#Computing the correlation matrix
cormat <- round(cor(df_selected),2)

#Creating the correlation heatmap with ggplot2
melted_cormat <- melt(cormat)

# Create the heatmap with correlation values displayed
heatmap_plot_selected <- ggplot(melted_cormat, aes(Var1, Var2, fill = value)) + 
  geom_tile() +                                # Create tiles based on correlation values
  geom_text(aes(label = round(value, 2)),       # Overlay the rounded correlation values on each tile
            color = 'black') + 
  scale_fill_gradient2(low = 'blue',             # Color for negative correlations
                       high = 'red',             # Color for positive correlations
                       mid = 'white',            # Mid-point (0 correlation)
                       midpoint = 0, limit = c(-1, 1), 
                       name = 'Pearson\nCorrelation') + 
  theme_classic() +                             # Use a minimal theme
  labs(title = 'Heatmap of Correlation'      # Plot title
) + theme(
  axis.title.x = element_blank(),
  axis.title.y = element_blank(),
  panel.grid.major = element_blank(),
  panel.border = element_blank(),
  panel.background = element_blank(),
  axis.ticks = element_blank(),
  legend.justification = c(1, 0),
  legend.position = c(0.6, 1.0),
  legend.direction = "horizontal")+
  guides(fill = guide_colorbar(barwidth = 7, barheight = 1,
                title.position = "top", title.hjust = 0.5))

# Display the heatmap
print(heatmap_plot_selected)

@
\caption{A Correlation Matrix of the Numeric Variables}
\label{Figure 2}
\end{figure}

