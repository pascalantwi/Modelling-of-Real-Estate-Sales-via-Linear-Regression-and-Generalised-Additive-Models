\caption{Model Evaluation for the Log Model and the Regression Model}
\label{Table 9}
<<echo=FALSE, results=tex>>=
# 3. Define a custom K-fold cross-validation function with factor level handling
custom_cv <- function(data, formula, response_var, k = 2) {
  set.seed(8204)
  n <- nrow(data)
  fold_indices <- sample(rep(1:k, length.out = n))
  
  mse_values <- numeric(k)
  r2_values <- numeric(k)
  
  for (i in 1:k) {
    train_data <- data[fold_indices != i, ]
    test_data <- data[fold_indices == i, ]
    
    # Fit model on training data
    model <- lm(formula, data = train_data)
    
    # Match factor levels in test data to training data
    factor_vars <- names(Filter(is.factor, train_data))
    for (f in factor_vars) {
      test_data[[f]] <- factor(test_data[[f]], levels = levels(train_data[[f]]))
    }
    
    # Predict on test data
    predictions <- predict(model, newdata = test_data)
    actual <- test_data[[response_var]]
    
    # Compute MSE and R²
    mse_values[i] <- mean((actual - predictions)^2)
    r2_values[i] <- cor(actual, predictions)^2
  }
  
  return(list(
    avg_mse = mean(mse_values),
    avg_r2 = mean(r2_values),
    mse_sd = sd(mse_values),
    r2_sd = sd(r2_values),
    rmse = sqrt(mean(mse_values))  # Add RMSE
  ))
}


# 4. Define the formulas for both models
original_formula <- as.formula("Salesprice~Quality+Finishedsquareft+Numberofbedrooms+
                               Adjacenttohighway+Numberofbathrooms+Airconditioning+
                               Garagesize+Pool+Style+Lotsize+YearBuilt")

log_formula <- as.formula("transformed_price~Quality+Finishedsquareft+Numberofbedrooms+
                               Adjacenttohighway+Numberofbathrooms+Airconditioning+
                               Garagesize+Pool+Style+Lotsize+YearBuilt")

# 5. Run cross-validation for both models
cv_original <- custom_cv(lm_data, original_formula, "Salesprice")
cv_log <- custom_cv(lm_data, log_formula, "transformed_price")

library(knitr)
library(tibble)
library(dplyr)

# Create your results table
cv_results <- tibble(
  Metric = c("MSE", "RMSE", "R_squared", "MSE_SD", "R_squared_SD"),
  `Original (Sales price scale)` = c(
    cv_original$avg_mse,
    cv_original$rmse,
    cv_original$avg_r2,
    cv_original$mse_sd,
    cv_original$r2_sd
  ),
  `Log-transformed (LogSales price scale)` = c(
    cv_log$avg_mse,
    cv_log$rmse,
    cv_log$avg_r2,
    cv_log$mse_sd,
    cv_log$r2_sd
  )
)

# Print the transposed table as LaTeX
kable(cv_results, format = "latex", booktabs = TRUE, digits = 4)

@
\end{table}


