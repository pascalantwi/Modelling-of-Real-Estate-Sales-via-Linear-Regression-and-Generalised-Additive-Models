\begin{figure}[H]
\centering
<<boxcox_plot, echo=FALSE, fig=TRUE, message=FALSE, warning=FALSE>>=
library(MASS)
library(ggplot2)

# Fit the initial linear model using lm_data
model_1 <- lm(Salesprice ~ Quality + Finishedsquareft + Numberofbedrooms +
                Adjacenttohighway + Numberofbathrooms + Airconditioning +
                Garagesize + Pool + Style + Lotsize + YearBuilt,
              data = lm_data)

# Perform Box-Cox transformation with a finely spaced Lambda range
bc <- boxcox(model_1, lambda = seq(-2, 2, 0.001), plotit = FALSE)

# Extract the optimal Lambda that maximizes the log-likelihood
optimal_lambda <- bc$x[which.max(bc$y)]

# Plot the Box-Cox log-likelihood curve
plot(bc, main = "Box-Cox Transformation", xlab = "Lambda", ylab = "Log-Likelihood")

# Annotate the optimal lambda on the plot
text(optimal_lambda, max(bc$y),
     labels = paste("Optimal Lambda =", round(optimal_lambda, 4)),
     pos = 4, col = "red", cex = 1.2)
@
\caption{Box-Cox Log-Likelihood Plot Showing Optimal Lambda}
\label{Figure 5}
\end{figure}

<<echo=FALSE>>=
# Apply Box-Cox transformation to Salesprice using the optimal lambda
lm_data$transformed_price <- 
  (lm_data$Salesprice^optimal_lambda - 1) / optimal_lambda
@

