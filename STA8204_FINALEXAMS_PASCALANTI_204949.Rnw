<<echo=FALSE, results=tex>>=
library(car)
library(knitr)

# Compute VIF
vif_values <- vif(model_1)

# Handle case when model includes factors: vif() returns matrix
if (is.matrix(vif_values)) {
  vif_df <- data.frame(
    Predictor = rownames(vif_values),
    VIF = round(vif_values[, "GVIF"], 3),
    Df = vif_values[, "Df"],
    Adjusted_GVIF = round(vif_values[, "GVIF^(1/(2*Df))"], 3)
  )
  kable(vif_df,
        format = "latex",
        booktabs = TRUE,
        col.names = c("Predictor", "GVIF", "Df", "Adjusted GVIF"))
} else {
  vif_df <- data.frame(
    Predictor = names(vif_values),
    VIF = round(vif_values, 3)
  )
  kable(vif_df,
        format = "latex",
        booktabs = TRUE,
        col.names = c("Predictor", "VIF"))
}
@
\end{table}

