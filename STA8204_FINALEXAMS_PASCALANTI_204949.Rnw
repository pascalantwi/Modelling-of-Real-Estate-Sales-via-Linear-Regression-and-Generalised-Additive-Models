<<echo=FALSE, results=tex>>=
library(broom)
library(knitr)

# Subset and rename variables
variable <- c("X1","X2","X3","X4","X5","X6","X7","X9","X10","X11","X12","year_category")
lm_data <- as.data.frame(data[, variable])
names(lm_data) <- c("Salesprice", "Finishedsquareft", "Numberofbedrooms", "Numberofbathrooms",
                    "Airconditioning", "Garagesize", "Pool", "Quality", "Style",
                    "Lotsize", "Adjacenttohighway", "YearBuilt")

# Ensure factor variables are treated correctly
lm_data$Style <- factor(lm_data$Style)

# Fit the linear model
model_1 <- lm(Salesprice ~ Quality + Finishedsquareft + Numberofbedrooms +
              Adjacenttohighway + Numberofbathrooms + Airconditioning +
              Garagesize + Pool + Style + Lotsize + YearBuilt,
              data = lm_data)

# Extract tidy summary
model_summary <- tidy(model_1)

# Output LaTeX-compatible table
kable(model_summary, format = "latex", booktabs = TRUE, digits = 3)
@
\end{table}

\begin{table}[H]
\centering
\caption{Summary Statistics for the Linear Regression Model}
\label{Table 3}
<<echo=FALSE, results=tex>>=
library(broom)
library(knitr)

# Get model summary as one-row data frame
model_summary <- glance(model_1)

# Transpose so all values show clearly
model_summary_t <- data.frame(
  Statistic = names(model_summary),
  Value = t(model_summary)
)

# Render clean LaTeX table
kable(model_summary_t,
      format = "latex",
      booktabs = TRUE,
      col.names = c("Statistic", "Value"),
      digits = 4)
@
\end{table}


\begin{figure}[H]
\centering
<<echo=FALSE, fig=TRUE>>=
# Get model diagnostics in tidy format
linearity_model <- augment(model_1)

# Create residuals vs. fitted values plot
p1 = ggplot(linearity_model, aes(x = .fitted, y = .resid)) +
  geom_point(alpha = 0.5) +
  geom_hline(yintercept = 0, linetype = "dashed", color = "red") +
  geom_smooth(method = "loess", se = FALSE, color = "blue") +
  labs(title = "Residuals vs Fitted Values",
       x = "Fitted Values",
       y = "Residuals")+
  theme_classic() + theme(plot.title = element_text(hjust = 0.5, size = 11), 
                          axis.title = element_text(size = 8), 
                          axis.title.y = element_text(angle = 90, vjust = 1), 
                          axis.text = element_text(size = 6))
# QQ plot of residuals  
p2 = ggplot(linearity_model, aes(sample = .resid)) +  
  stat_qq() +  
  stat_qq_line(color = "red") +  
  labs(title = "Q-Q Plot of Residuals",  
       x = "Theoretical Quantiles",  
       y = "Sample Quantiles")+
  theme_classic() + theme(plot.title = element_text(hjust = 0.5, size = 11), 
                          axis.title = element_text(size = 8), 
                          axis.title.y = element_text(angle = 90, vjust = 1), 
                          axis.text = element_text(size = 6))  
  
# Histogram of residuals  
p3 <- ggplot(linearity_model, aes(x = .resid)) +  
  geom_histogram(bins = 30, fill = "lightblue", color = "black", alpha = 0.7) +  
  labs(title = "Histogram of Residuals",  
       x = "Residuals",  
       y = "Frequency")+
  theme_classic() + theme(plot.title = element_text(hjust = 0.5, size = 11), 
                          axis.title = element_text(size = 8), 
                          axis.title.y = element_text(angle = 90, vjust = 1), 
                          axis.text = element_text(size = 6)) 

# Combine the plots using patchwork  
p1 + p2 + p3 
@
\caption{A Q-Q, Histogram and Residuals vs. Fitted values Plot}
\label{Figure 3}
\end{figure}

\begin{table}[H]
\centering
\caption{Diagnostic Tests: Breusch-Pagan and Shapiro-Wilk}
\label{Table 4}
<<echo=FALSE, results=tex>>=
# Load required package
library(knitr)

# Run Breusch-Pagan Test
bp_test <- bptest(model_1)

# Run Shapiro-Wilk Test
shapiro_test <- shapiro.test(linearity_model$.resid)

# Create combined result table
diagnostic_results <- data.frame(
  Test = c("Breusch-Pagan", "Shapiro-Wilk"),
  Statistic = c(round(as.numeric(bp_test$statistic), 3),
                round(as.numeric(shapiro_test$statistic), 4)),
  p_value = c(round(as.numeric(bp_test$p.value), 4),
              round(as.numeric(shapiro_test$p.value), 4))
)

# Print LaTeX table
kable(diagnostic_results,
      format = "latex",
      booktabs = TRUE,
      col.names = c("Test", "Test Statistic", "P-value"))
@
\end{table}

