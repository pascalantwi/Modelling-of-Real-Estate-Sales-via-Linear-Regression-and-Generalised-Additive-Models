\begin{table}[H]
\centering
\caption{Rank of the Predictors for the Log Model (RMSE)}
\label{Table 11}
<<echo=FALSE, results=tex>>=
  set.seed(8204)
# Selected variables (including factors)
selected <- c("transformed_price", "Quality", "Finishedsquareft",
              "Numberofbedrooms", "Adjacenttohighway", "Numberofbathrooms",
              "Airconditioning", "Garagesize", "Style","Pool", "Lotsize", "YearBuilt")

cv_data <- lm_data[, selected]

# Split predictors and target
predictors <- cv_data[, -which(names(cv_data) == "transformed_price")]
target <- cv_data$transformed_price
predictor_names <- colnames(predictors)

# Cross-validation function for RMSE calculation
cv_lm <- function(data, target_values, target_name, predictor, k = 2) {
  n <- nrow(data)
  folds <- sample(rep(1:k, length.out = n))
  rmse_vals <- numeric(k)
  
  factor_cols <- names(data)[sapply(data, is.factor)]
  
  for (i in 1:k) {
    train_idx <- which(folds != i)
    test_idx <- which(folds == i)
    
    train <- data[train_idx, ]
    test <- data[test_idx, ]
    
    # Ensure consistent factor levels
    for (col in factor_cols) {
      train[[col]] <- factor(train[[col]], levels = levels(data[[col]]))
      test[[col]]  <- factor(test[[col]], levels = levels(data[[col]]))
    }
    
    train[[target_name]] <- target_values[train_idx]
    
    formula <- as.formula(paste(target_name, "~", predictor))
    model <- lm(formula, data = train)
    
    preds <- predict(model, newdata = test)
    actuals <- target_values[test_idx]
    rmse_vals[i] <- sqrt(mean((actuals - preds)^2))
  }
  
  mean(rmse_vals)
}

# Execution (correct)
results <- data.frame(Predictor = predictor_names, RMSE = NA_real_)

for (i in seq_along(predictor_names)) {
  pred <- predictor_names[i]
  results$RMSE[i] <- cv_lm(
    data = cv_data,              # Contains all predictors + target
    target_values = target,      # Numeric vector of target values
    target_name = "transformed_price",  # Target column name as string
    predictor = pred,            # Current predictor name
    k = 2
  )
}

# Rank predictors by RMSE (lower is better)
results <- results[order(results$RMSE), ]

# Print the table in LaTeX format
results |>
  kable(format = "latex", booktabs = TRUE, digits = 4,
        col.names = c("Predictor", "RMSE"))
@
\end{table}


\begin{table}[H]
\centering
\caption{Ranking the Predictors Using the GAM (RMSE)}
\label{Table 12}
<<echo=FALSE, results=tex>>=
# Data Preparation
library(mgcv)  # For GAM implementation
set.seed(8204)
# Selected variables (including factors)
selected <- c("transformed_price", "Quality", "Finishedsquareft",
              "Numberofbedrooms", "Adjacenttohighway", "Numberofbathrooms",
              "Airconditioning", "Garagesize", "Pool","Style","Lotsize", "YearBuilt")

# Create data frame with proper factor handling
cv_data <- lm_data[, selected]

# Split predictors and target
predictors <- cv_data[, -which(names(cv_data) == "transformed_price")]
target <- cv_data$transformed_price
predictor_names <- colnames(predictors)

# Cross-Validation Function for GAM
cv_gam <- function(data, target_values, target_name, predictor, k = 2) {
  n <- nrow(data)
  folds <- sample(rep(1:k, length.out = n))
  rmse_vals <- numeric(k)

  factor_cols <- names(data)[sapply(data, is.factor)]

  for (i in 1:k) {
    train_idx <- which(folds != i)
    test_idx <- which(folds == i)

    train <- data[train_idx, ]
    test <- data[test_idx, ]

    # Ensure consistent factor levels across folds
    for (col in factor_cols) {
      if (col %in% names(train) && col %in% names(test)) {
        common_levels <- union(levels(data[[col]]), levels(data[[col]]))
        train[[col]] <- factor(train[[col]], levels = common_levels)
        test[[col]]  <- factor(test[[col]], levels = common_levels)
      } else if (col %in% names(train)) {
        train[[col]] <- factor(train[[col]], levels = levels(data[[col]]))
      } else if (col %in% names(test)) {
        test[[col]]  <- factor(test[[col]], levels = levels(data[[col]]))
      }
    }

    train[[target_name]] <- target_values[train_idx]

    # Determine formula
    if (is.factor(train[[predictor]])) {
      formula <- as.formula(paste(target_name, "~", predictor))
    } else {
      unique_vals <- length(unique(train[[predictor]]))
      if (unique_vals < 3) {
        formula <- as.formula(paste(target_name, "~", predictor))  # Treat as linear
      } else {
        k_val <- min(4, unique_vals)
        formula <- as.formula(paste(target_name, "~ s(", predictor, ", k = ", k_val, ")"))
      }
    }

    # Fit the GAM model with error handling
    model <- tryCatch(
      gam(formula, data = train),
      error = function(e) {
        warning(paste("GAM fitting error for predictor", predictor, "in fold", i, ":", e$message))
        NULL
      }
    )

    # Predict and compute RMSE
    if (is.null(model)) {
      rmse_vals[i] <- NA  # Assign NA if model fails
    } else {
      preds <- tryCatch(predict(model, newdata = test), error = function(e) NA)
      actuals <- target_values[test_idx]
      if (!any(is.na(preds))) {
        rmse_vals[i] <- sqrt(mean((actuals - preds)^2))
      } else {
        rmse_vals[i] <- NA
      }
    }
  }

  mean(rmse_vals, na.rm = TRUE)
}

##------------------Rank Predictors
result <- data.frame(Predictor = predictor_names, RMSE = NA_real_)

for (i in seq_along(predictor_names)) {
  pred <- predictor_names[i]

  # Skip if predictor has < 2 unique values
  if (length(unique(lm_data[[pred]])) < 2) {
    warning(paste("Skipping predictor:", pred, "- too few unique values"))
    next
  }

  result$RMSE[i] <- cv_gam(
    data = lm_data[, c("transformed_price", pred)], # Pass only the target and current predictor
    target_values = target,
    target_name = "transformed_price",
    predictor = pred,
    k = 2
  )
}

# Sort by RMSE
result <- result[order(result$RMSE), ]

# Print the table in LaTeX format
result |>
  kable(format = "latex", booktabs = TRUE, digits = 4,
        col.names = c("Predictor", "RMSE"))
@
\end{table}

\begin{table}[H]
\centering
\caption{Comparison of RMSE for Log and GAM Models by the Predictors}
\label{Table 13}
<<echo=FALSE, results=tex>>=
## Compare Models for Each Predictor
set.seed(8204)
results <- data.frame(
  Predictor = predictor_names,
  LM_RMSE = NA_real_,
  GAM_RMSE = NA_real_
)

for (i in seq_along(predictor_names)) {
  pred <- predictor_names[i]
  results$LM_RMSE[i] <- cv_lm(cv_data, target, "transformed_price", pred, k = 10)
  results$GAM_RMSE[i] <- cv_gam(cv_data[, c("transformed_price", pred)], target, "transformed_price", pred, k = 10)
}

# Calculate RMSE differences
results$RMSE_Diff <- results$GAM_RMSE - results$LM_RMSE
results$Better_Model <- ifelse(results$RMSE_Diff < 0, "GAM", "LM")

# Sort by RMSE difference
results <- results[order(abs(results$RMSE_Diff), decreasing = TRUE), ]

# Print the table in LaTeX format
results |>
  kable(format = "latex", booktabs = TRUE, digits = 4,
        col.names = c("Predictor", "LM RMSE", "GAM RMSE", "RMSE Difference", "Better Model"))
@
\end{table}

